# Client (Vite) — safe to expose in the browser bundle
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Set to false for fully local development without Supabase
VITE_CLOUD_FIRST=true

# Set to true only for local debugging — bypasses the write proxy (not for production)
# VITE_DIRECT_SUPABASE_WRITES=true

# Optional API host override for Capacitor native builds (required for store builds)
VITE_API_BASE_URL=https://tradeshow-passport-raffle.vercel.app

# Plan 3 — enable after SCAN_SIGNING_SECRET is set on Vercel
# VITE_SIGNED_QR_CODES=true

# Plan 3 — enable after Supabase Auth email is configured for attendees
# VITE_ATTENDEE_MAGIC_LINK=true

# Plan 3 — read booths/settings from public views instead of passport_state JSON
# VITE_NORMALIZED_READS=true

# Server (Vercel) — never prefix with VITE_
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional explicit server URL (falls back to VITE_SUPABASE_URL)
# SUPABASE_URL=https://your-project.supabase.co

ADMIN_INVITE_REDIRECT_URL=https://your-app.vercel.app/admin
# ADMIN_INVITE_DEEP_LINK_URL=yourapp://admin

# Plan 2C write proxy uses service role internally (no extra vars required)

# Plan 3 — HMAC secret for signed booth QR codes (generate: openssl rand -base64 32)
# SCAN_SIGNING_SECRET=

# Plan 3 — reject unsigned scan codes once all booths have signed QRs printed
# SCAN_SIGNING_REQUIRED=true

# Plan 3 — dual-write JSON patches into normalized tables (enable after backfill)
# NORMALIZED_DUAL_WRITE=true

# Plan 3 — persist admin audit actions to admin_audit_log table
# AUDIT_LOG_TO_DB=true
