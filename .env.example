# Client (Vite) — safe to commit; copy to .env and fill in real values
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_CLOUD_FIRST=true
# VITE_API_BASE_URL=https://your-deployment.vercel.app
# VITE_DIRECT_SUPABASE_WRITES=true

# Vercel serverless API routes (never expose service role to the client)
SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_INVITE_REDIRECT_URL=https://your-deployment.vercel.app/admin
# ADMIN_INVITE_DEEP_LINK_URL=tradeshowpassport://admin

# Local dev: proxy /api to Vercel or local API server
# ADMIN_API_PROXY_TARGET=http://127.0.0.1:3001
# LOCAL_API_PORT=3001
