# Client-side (Vite) — copy to .env and fill in from Supabase Project Settings -> API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Enable cloud sync (set to false for local-only dev)
VITE_CLOUD_FIRST=true

# Optional: override API host for native builds (defaults to production Vercel URL)
VITE_API_BASE_URL=https://your-app.vercel.app

# Server-side only (Vercel environment variables — never use VITE_ prefix)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ADMIN_INVITE_REDIRECT_URL=https://your-app.vercel.app/admin

# Optional: opens invite/reset links in the native app (also allowlist in Supabase Auth)
ADMIN_INVITE_DEEP_LINK_URL=landfxpassport://admin
